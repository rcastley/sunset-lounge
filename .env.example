# Copy this file to `.env` and fill it in.
# `.env` is read automatically by docker compose. Never commit it.

# Required. A long random string. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SUNSET_SECRET=

# Required only on the very first startup, before any staff exist.
# After that initial account is created you can remove these two lines.
SUNSET_INITIAL_STAFF_NAME=Owner
SUNSET_INITIAL_STAFF_PIN=

# Optional. Port exposed to the host. Defaults to 5800.
# HOST_PORT=5800

# Optional. Set to 1 once you're serving over HTTPS so session cookies
# are marked Secure.
# SUNSET_COOKIE_SECURE=1

# Optional. Set to 1 on a fresh install to populate demo clients,
# packages and sessions so you can click around immediately.
# SUNSET_SEED_DEMO=1
